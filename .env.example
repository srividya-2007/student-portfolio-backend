# Railway backend variables
# If your Railway MySQL service has a different name, replace "MySQL" below
# with the exact Railway service name before importing.

DB_URL=jdbc:mysql://${{MySQL.MYSQLHOST}}:${{MySQL.MYSQLPORT}}/${{MySQL.MYSQLDATABASE}}?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}
DB_DRIVER=com.mysql.cj.jdbc.Driver
HIBERNATE_DIALECT=org.hibernate.dialect.MySQLDialect

JWT_SECRET=replace-with-a-long-random-secret
APP_FRONTEND_URL=https://your-frontend-domain
CORS_ALLOWED_ORIGINS=https://your-frontend-domain
CORS_ALLOWED_ORIGIN_PATTERNS=https://*.vercel.app,https://*.netlify.app,https://*.up.railway.app
APP_AUTH_RESET_OTP_EXPIRY_MINUTES=10

# Uploaded files are written locally by the app. For production, attach a Railway
# volume and mount it to /app/uploads so files survive redeploys.
APP_UPLOAD_DIR=/app/uploads

# Optional SMTP settings for OTP emails
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_SMTP_STARTTLS_REQUIRED=false
